{
  "name": "@knaw-huc/panoptes-react-blocks",
  "version": "0.0.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knaw-huc/panoptes-react-blocks.git"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/panoptes-react-blocks.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && npm run test:coverage && vite build",
    "dev": "vite",
    "build:watch": "vite build --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint lib",
    "clean": "rm -rf coverage && rm -rf dist"
  },
  "peerDependencies": {
    "@knaw-huc/panoptes-react": "*",
    "@tanstack/react-router": "*",
    "react": "19",
    "react-dom": "19"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "ol": "^10.8.0",
    "react-error-boundary": "^4.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@knaw-huc/panoptes-react": "^0.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "i18next": "^26.0.5"
  }
}
